rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Web Admin override ────────────────────────────────────────────────
    // Web admins have unrestricted access to all collections, including
    // the database-reset operation which deletes documents normally blocked
    // from deletion (students, users, financialLogs, etc.).
    function isWebAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'web_admin';
    }
    match /{document=**} {
      allow read, write, delete: if isWebAdmin();
    }

    // ── students ─────────────────────────────────────────────────────────
    match /students/{studentId} {
      // TODO (Security C-03 — KNOWN RISK): Students do not use Firebase Auth.
      // Until custom-token auth is implemented (signInWithCustomToken via Cloud
      // Function), unauthenticated reads are required for login-time queries and
      // throughout the student portal session.
      // RISK: Any unauthenticated client can bulk-query all student records
      // (names, DOBs, guardian contacts). Planned fix: Firebase Custom Token login.
      allow read: if true;

      // Authenticated staff can update any field (status, class, clearance, etc.)
      allow update: if request.auth != null;

      // Unauthenticated students can only update their own contact fields
      allow update: if request.auth == null
        && request.resource.data.diff(resource.data)
             .affectedKeys().hasOnly(['email', 'phone', 'hasEmail', 'updatedAt']);

      // Only authenticated staff can enrol new students
      allow create: if request.auth != null;

      allow delete: if false;
    }

    // ── users ────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Unauthenticated: read pending OTP record for first-time login
      allow read: if request.auth == null
        && resource.data.role == 'student'
        && resource.data.otpUsed == false;

      // Unauthenticated: read own record for returning-student password verification
      allow read: if request.auth == null
        && resource.data.role == 'student'
        && resource.data.hasSetupPassword == true;

      // Authenticated users: read their own doc or any doc for admin purposes
      allow read: if request.auth != null;

      // Staff create their own doc on signup; also create student user docs (OTP)
      allow create: if request.auth != null;

      // Unauthenticated: set password on a pending OTP record (first-time setup)
      allow update: if request.auth == null
        && resource.data.role == 'student'
        && resource.data.otpUsed == false
        && request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['password', 'hasSetupPassword', 'otpUsed',
                       'studentId', 'regNumber', 'name', 'class', 'updatedAt']);

      // Authenticated staff can update user records
      allow update: if request.auth != null;

      allow delete: if false;
    }

    // ── portalSettings ───────────────────────────────────────────────────
    match /portalSettings/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
             in ['web_admin', 'admin', 'staff'];
    }

    // ── proofOfPayments ──────────────────────────────────────────────────
    match /proofOfPayments/{docId} {
      // Authenticated staff (bursar) OR unauthenticated student portal
      allow read: if request.auth != null
        || (request.auth == null && resource.data.studentId != null);

      // Students create their own POPs (unauthenticated); staff can create too
      allow create: if request.auth != null
        || (request.auth == null && request.resource.data.studentId != null);

      allow update, delete: if false;
    }

    // ── academicResults ──────────────────────────────────────────────────
    match /academicResults/{docId} {
      // Authenticated staff (Student Admin) OR unauthenticated student portal
      allow read: if request.auth != null
        || (request.auth == null && resource.data.studentId != null);

      // Only authenticated staff can write academic results
      allow write: if request.auth != null;
    }

    // ── feeAccounts ──────────────────────────────────────────────────────
    match /feeAccounts/{docId} {
      // Authenticated staff (bursar) OR unauthenticated student portal
      allow read: if request.auth != null
        || (request.auth == null && resource.data.studentId != null);

      // Only authenticated staff (bursar) can write fee accounts
      allow write: if request.auth != null;
    }

    // ── receipts ─────────────────────────────────────────────────────────
    match /receipts/{docId} {
      // Authenticated staff (bursar) OR unauthenticated student portal
      allow read: if request.auth != null
        || (request.auth == null && resource.data.studentId != null);

      // Only authenticated bursar can create/update receipts
      allow write: if request.auth != null;
    }

    // ── notifications ─────────────────────────────────────────────────────
    match /notifications/{docId} {
      allow read: if request.auth != null
        || (request.auth == null && resource.data.studentId != null);

      // Students mark their own notifications as read (unauthenticated)
      allow update: if request.auth != null
        || (request.auth == null
          && resource.data.studentId != null
          && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['read']));

      // Only authenticated staff create notifications
      allow create: if request.auth != null;
      allow delete: if false;
    }

    // ── otpLogs (web-admin only) ──────────────────────────────────────────
    match /otpLogs/{docId} {
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
             in ['web_admin', 'admin', 'staff'];
    }

    // ── securityLogs ──────────────────────────────────────────────────────
    match /securityLogs/{docId} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
             in ['web_admin', 'admin', 'staff'];
      allow create: if true;
      allow update, delete: if false;
    }

    // ── expenses ──────────────────────────────────────────────────────────
    match /expenses/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── financialLogs ─────────────────────────────────────────────────────
    // Immutable audit trail. Anyone can create (bursar writes from Firebase Auth
    // session); reads restricted to authenticated admin/staff roles.
    match /financialLogs/{docId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
             in ['web_admin', 'admin', 'staff'];
      allow create: if true;
      allow update, delete: if false;
    }

    // ── activeSessions ────────────────────────────────────────────────────
    // C-07 FIXED: students now use signInWithCustomToken (verifyStudentPassword
    // Cloud Function) so request.auth.uid == uid is always satisfied.
    match /users/{uid}/activeSessions/{sessionId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == uid;
    }

    // ── loginAttempts ─────────────────────────────────────────────────────
    match /loginAttempts/{docId} {
      allow read, create: if true;
      // Only allow updates that either increment the counter (record failure)
      // or reset it while NOT actively locked (successful login clears counter).
      // Prevents attackers from resetting their own lockout to bypass brute-force protection.
      allow update: if
        request.resource.data.failedAttempts >= resource.data.failedAttempts
        || (request.resource.data.failedAttempts == 0
            && (resource.data.lockedUntil == null
                || resource.data.lockedUntil.toMillis() <= request.time.toMillis()));
      allow delete: if false;
    }

    // ── studyMaterials ────────────────────────────────────────────────────
    // Teachers (Firebase Auth) upload notes and past papers; students
    // (unauthenticated) can read metadata and download files.
    match /studyMaterials/{docId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── otpSecret subcollection ───────────────────────────────────────────
    // OTP code is stored here rather than on the parent users doc, so bulk
    // queries on users/ do not expose active OTP codes.
    match /users/{uid}/otpSecret/current {
      // Unauthenticated students can read by exact path to verify their OTP.
      // list is blocked — attackers cannot enumerate OTP codes in bulk.
      allow get: if request.auth == null;
      allow list, write, delete: if request.auth != null;
    }

  }
}
