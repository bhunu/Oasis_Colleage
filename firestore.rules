rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── students ─────────────────────────────────────────────────────────
    match /students/{studentId} {
      // Students don't use Firebase Auth, so unauthenticated reads are required
      // for login-time queries and throughout the student portal session.
      // Full restriction requires migrating students to Firebase Auth (C-03 note).
      allow read: if true;

      // Authenticated staff can update any field (status, class, clearance, etc.)
      allow update: if request.auth != null;

      // Unauthenticated students can only update their own contact fields
      allow update: if request.auth == null
        && request.resource.data.diff(resource.data)
             .affectedKeys().hasOnly(['email', 'phone', 'hasEmail', 'updatedAt']);

      // Only authenticated staff can enrol new students
      allow create: if request.auth != null;

      allow delete: if false;
    }

    // ── users ────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Unauthenticated: read pending OTP record for first-time login
      allow read: if request.auth == null
        && resource.data.role == 'student'
        && resource.data.otpUsed == false;

      // Authenticated users: read their own doc or any doc for admin purposes
      allow read: if request.auth != null;

      // Staff create their own doc on signup; also create student user docs (OTP)
      allow create: if request.auth != null;

      // Unauthenticated: set password on a pending OTP record (first-time setup)
      allow update: if request.auth == null
        && resource.data.role == 'student'
        && resource.data.otpUsed == false
        && request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['password', 'hasSetupPassword', 'otpUsed',
                       'studentId', 'regNumber', 'name', 'class', 'updatedAt']);

      // Authenticated staff can update user records
      allow update: if request.auth != null;

      allow delete: if false;
    }

    // ── portalSettings ───────────────────────────────────────────────────
    match /portalSettings/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
             in ['web_admin', 'admin', 'staff'];
    }

    // ── proofOfPayments ──────────────────────────────────────────────────
    match /proofOfPayments/{docId} {
      // Authenticated staff (bursar) OR unauthenticated student portal
      allow read: if request.auth != null
        || (request.auth == null && resource.data.studentId != null);

      // Students create their own POPs (unauthenticated); staff can create too
      allow create: if request.auth != null
        || (request.auth == null && request.resource.data.studentId != null);

      allow update, delete: if false;
    }

    // ── academicResults ──────────────────────────────────────────────────
    match /academicResults/{docId} {
      // Authenticated staff (Student Admin) OR unauthenticated student portal
      allow read: if request.auth != null
        || (request.auth == null && resource.data.studentId != null);

      // Only authenticated staff can write academic results
      allow write: if request.auth != null;
    }

    // ── feeAccounts ──────────────────────────────────────────────────────
    match /feeAccounts/{docId} {
      // Authenticated staff (bursar) OR unauthenticated student portal
      allow read: if request.auth != null
        || (request.auth == null && resource.data.studentId != null);

      // Only authenticated staff (bursar) can write fee accounts
      allow write: if request.auth != null;
    }

    // ── receipts ─────────────────────────────────────────────────────────
    match /receipts/{docId} {
      // Authenticated staff (bursar) OR unauthenticated student portal
      allow read: if request.auth != null
        || (request.auth == null && resource.data.studentId != null);

      // Only authenticated bursar can create/update receipts
      allow write: if request.auth != null;
    }

    // ── notifications ─────────────────────────────────────────────────────
    match /notifications/{docId} {
      allow read: if request.auth != null
        || (request.auth == null && resource.data.studentId != null);

      // Students mark their own notifications as read (unauthenticated)
      allow update: if request.auth != null
        || (request.auth == null
          && resource.data.studentId != null
          && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['read']));

      // Only authenticated staff create notifications
      allow create: if request.auth != null;
      allow delete: if false;
    }

    // ── otpLogs (web-admin only) ──────────────────────────────────────────
    match /otpLogs/{docId} {
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
             in ['web_admin', 'admin', 'staff'];
    }

    // ── securityLogs ──────────────────────────────────────────────────────
    match /securityLogs/{docId} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
             in ['web_admin', 'admin', 'staff'];
      allow create: if true;
      allow update, delete: if false;
    }

    // ── financialLogs ─────────────────────────────────────────────────────
    // Immutable audit trail. Bursar portal writes (unauthenticated session)
    // are allowed to create; reads restricted to authenticated admin roles.
    match /financialLogs/{docId} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
             in ['web_admin', 'admin', 'staff'];
      allow create: if true;
      allow update, delete: if false;
    }

    // ── activeSessions ────────────────────────────────────────────────────
    // C-07 FIXED: students now use signInWithCustomToken (verifyStudentPassword
    // Cloud Function) so request.auth.uid == uid is always satisfied.
    match /users/{uid}/activeSessions/{sessionId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == uid;
    }

    // ── loginAttempts ─────────────────────────────────────────────────────
    match /loginAttempts/{docId} {
      allow read, create, update: if true;
      allow delete: if false;
    }

  }
}
