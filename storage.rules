rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Public site assets — images only for authenticated writes
    match /gallery/{allPaths=**} { allow read: if true; allow write: if request.auth != null && request.resource.contentType.matches('image/.*'); }
    match /staff/{allPaths=**}   { allow read: if true; allow write: if request.auth != null && request.resource.contentType.matches('image/.*'); }
    match /news/{allPaths=**}    { allow read: if true; allow write: if request.auth != null && request.resource.contentType.matches('image/.*'); }

    // Expense receipts — authenticated bursar writes; images and PDF only
    match /expenses/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf');
    }

    // Student proof of payment — must be an authenticated student uploading to their own reg_number folder.
    // Uses students/{auth.uid} directly because Firebase Auth uid == Firestore student doc ID (set by Cloud Function).
    match /proofOfPayments/{studentFolder}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/students/$(request.auth.uid)).data.reg_number == studentFolder
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf');
    }

    // Exeat supporting documents — same ownership model as proofOfPayments
    match /exeat-docs/{studentFolder}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/students/$(request.auth.uid)).data.reg_number == studentFolder
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf');
    }

    // Fallback deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
