# ════════════════════════════════════════════════════════════════════════════
#  SCHOOL DEPLOYMENT TEMPLATE — copy this to .env and fill in the values
#  Generated by Oasis Systems SaaS Platform
# ════════════════════════════════════════════════════════════════════════════

# ─── EmailJS ──────────────────────────────────────────────────────────────────
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# ─── Firebase (create a new Firebase project for each school) ─────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── School Identity ─────────────────────────────────────────────────────────
# These appear in all portals, login pages, receipts, and official documents.
# No code changes needed — set these values and rebuild.
VITE_SCHOOL_NAME=             # Full name  e.g. "Hillside High School"
VITE_SCHOOL_SHORT_NAME=       # Short name e.g. "Hillside High" (used in sidebars)
VITE_SCHOOL_ADDRESS=          # Location   e.g. "Bulawayo, Zimbabwe"
VITE_SCHOOL_TAGLINE=          # Optional tagline shown on some pages
VITE_SCHOOL_EMAIL=            # Optional contact email
VITE_SCHOOL_PHONE=            # Optional contact phone

# ─── SaaS License ────────────────────────────────────────────────────────────
# Obtain these from the system developer (Oasis Systems)
VITE_LICENSE_TOKEN=          # JWT token issued by developer Super Admin panel
VITE_LICENSE_SECRET=         # Signing secret provided by developer (keep private)

# Leave blank on school deployments — only the developer sets this to "true"
VITE_IS_DEVELOPER_INSTANCE=

# ─── Developer Branding (shown on expired/invalid license screens) ────────────
VITE_DEVELOPER_NAME=Oasis Systems
VITE_DEVELOPER_EMAIL=mabhunure@gmail.com
VITE_DEVELOPER_PHONE= +263 775 712 114

# ─── Super Admin (leave blank — only the developer sets this) ─────────────────
VITE_SUPER_ADMIN_EMAIL=
VITE_SUPER_ADMIN_SECRET=
